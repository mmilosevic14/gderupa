{
  "name": "gderupa",
  "version": "0.1.0",
  "description": "Infrastructure reporting PWA for Serbia - Citizen-driven road and infrastructure issue mapping",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "next build && npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "deploy:cf": "npm run build:cf && npx wrangler pages deploy .vercel/output/static --project-name gderupa",
    "sync:cf:secrets": "powershell -ExecutionPolicy Bypass -File scripts/sync-cloudflare-secrets.ps1"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.3.0",
    "@supabase/supabase-js": "^2.38.0",
    "@supabase/ssr": "^0.0.13",
    "react-map-gl": "^7.1.0",
    "mapbox-gl": "^2.15.0",
    "react-leaflet": "^4.2.0",
    "leaflet": "^1.9.0",
    "zustand": "^4.4.0",
    "axios": "^1.6.0",
    "next-pwa": "^5.6.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.50.0",
    "eslint-config-next": "^14.3.0",
    "@types/leaflet": "^1.9.0",
    "@cloudflare/next-on-pages": "^1.13.14",
    "wrangler": "^3.114.14"
  }
}
